# OpenAI API 설정
OPENAI_API_KEY=your-openai-api-key-here
EMBEDDING_MODEL=text-embedding-3-large
LLM_MODEL=gpt-4-turbo
EVALUATION_MODEL=gpt-4o
LLM_TEMPERATURE=0.3

# Max Tokens 설정
MAX_TOKENS_GENERATION=1000
MAX_TOKENS_INTENT=500
MAX_TOKENS_EVALUATION=1000
MAX_TOKENS_MULTIQUERY=300


# Voyage 리랭커 설정 
VOYAGE_API_KEY=your-voyage-api-key-here
VOYAGE_RERANKER_MODEL=rerank-2.5
VOYAGE_TOP_K=5            # Voyage API 리랭킹 개수
USE_RERANKER=true

# 청킹 설정
CASE_CHUNK_SIZE=600
CASE_CHUNK_OVERLAP=150
LAW_CHUNK_SIZE=500
LAW_CHUNK_OVERLAP=125

# 검색 설정
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5          # 리랭킹 후 최종 선택 개수 

# 재시도별 검색 문서 수
RETRY_0_K=10
RETRY_1_K=15
RETRY_2_K=20

# 평가 설정 (원래 로직)
# 통과 조건: faithfulness >= 0.5 AND relevancy >= 0.7
# Fallback: 0.1 < faithfulness < 0.5 AND relevancy >= 0.8
MIN_PASSING_SCORE=0.7
FAITHFULNESS_WEIGHT=0.5
RELEVANCY_WEIGHT=0.5

# 재시도 설정
MAX_RETRY_COUNT=3
RETRY_ON_EVAL_FAIL=true
RETRY_ON_EMPTY=true

# 로그 레벨
LOG_LEVEL=INFO
